# ==============================================================================
# Psychage Workspace .gitignore
# ==============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
# Finder/iCloud byte-identical dup of .github/CODEOWNERS — keeps reappearing
.github/CODEOWNERS 2

# ─────────────────────────────────────────────────────────────────────────────
# GitKraken metadata (auto-created on every git init via global template)
# ─────────────────────────────────────────────────────────────────────────────
gk/

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code — personal-to-this-project settings
# settings.json is project-shared (committed); settings.local.json is personal.
# Hooks-managed history files also stay personal.
# ─────────────────────────────────────────────────────────────────────────────
.claude/settings.local.json
.claude/projects/
.claude/history/
.claude/sessions/

# ─────────────────────────────────────────────────────────────────────────────
# Environment & secrets — never commit
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
credentials.json
secrets.json
.aws/
.ssh/

# ─────────────────────────────────────────────────────────────────────────────
# Node / Bun
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
.pnp.*
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# Build outputs (Expo / EAS / TS / Vite — keep all preemptive)
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
.expo/
.expo-shared/
web-build/
.next/
.turbo/
.cache/
.parcel-cache/
.vite/
.eas/

# Expo native build artifacts
ios/build/
ios/Pods/
ios/Podfile.lock
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/local.properties
android/keystores/
*.keystore
!debug.keystore
*.p8
*.p12
*.mobileprovision
*.orig.*

# ─────────────────────────────────────────────────────────────────────────────
# Test / coverage
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.vitest-cache/
playwright-report/
test-results/

# ─────────────────────────────────────────────────────────────────────────────
# Editor / IDE — track shared config (.vscode/extensions.json, .cursor/rules)
# but ignore personal local state
# ─────────────────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json
!.vscode/tasks.json
.idea/
# Cursor IDE — vendored skills mirror user-level Claude Code skills (1.2M).
# Selectively un-ignore .cursor/rules/ later if team-shared rules needed.
.cursor/
*.swp
*.swo
*~
.history/
.ionide/

# ─────────────────────────────────────────────────────────────────────────────
# OS — Windows / Linux (cross-platform safety)
# ─────────────────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log

# ─────────────────────────────────────────────────────────────────────────────
# Misc — task files generated by AI tools, runtime artifacts
# ─────────────────────────────────────────────────────────────────────────────
tasks.json
tasks/
.shopify
.claude-cache/
graphify-out/

# ─────────────────────────────────────────────────────────────────────────────
# Sentry / sourcemap upload tokens
# ─────────────────────────────────────────────────────────────────────────────
.sentryclirc
sourcemaps/

# ─────────────────────────────────────────────────────────────────────────────
# Archive / backup artifacts that don't belong in repo
# ─────────────────────────────────────────────────────────────────────────────
*.bak
*.backup
*.old
*.tmp
*-backup-*

# ─────────────────────────────────────────────────────────────────────────────
# What is explicitly NOT ignored — committed shared config
# (Listed for clarity, not enforcement — these aren't matched above.)
# ─────────────────────────────────────────────────────────────────────────────
# CLAUDE.md                  ← project rulebook (committed)
# PROJECT_CONTEXT.md         ← comprehensive context (committed)
# .claude/settings.json      ← project-shared Claude Code config (committed when populated)
# .cursor/rules/             ← un-ignore selectively if team-shared Cursor rules added
# learnings.md               ← project learnings (committed when it exists)
# rules/                     ← project rules (committed when they exist)

# Smoke-test spec folder used during phase deploys; never commit
.specs/_smoke_test/

# Phase-close staging files (paste-ready content for atomic close commits); local-only
PHASE_*_STAGING_*.md

# Session implementation reports (Claude Code artifacts at root); local-only
IMPLEMENTATION_REPORT_*.md

# Generated SessionEnd metrics output; local-only
_metrics.jsonl

# ─────────────────────────────────────────────────────────────────────────────
# Phase 6 — Expo / pnpm additions (most Expo paths already covered above)
# ─────────────────────────────────────────────────────────────────────────────
*.jks
.pnpm-store/
