{
  "cli": {
    "version": "20.2.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.22.3",
      "ios": {
        "simulator": true
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "node": "22.22.3",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "22.22.3"
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "node": "22.22.3",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
